{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++.exe build active file",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-O3",
        "-march=native",
        "-flto",
        "-g",
        "-I",
        "include",
        "src/main.cpp",
        "src/board.cpp",
        "src/moveGen.cpp",
        "-o",
        "${workspaceFolder}/app.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build all source files together"
    }
  ],
  "version": "2.0.0"
}